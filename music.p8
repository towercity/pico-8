pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	music(0)
end

function _update()	
	-- atm: gets the four playing sfx
	tracks={}
	for i=46,49 do
		add(tracks,stat(i))
	end
end

function _draw()
	cls()
	
	for track in all(tracks) do 
		print(get_sfx_speed(track))
		--print(track)
	end
		
end
-->8
--sfx
-- credit: https://www.lexaloffle.com/bbs/?tid=55289


function get_sfx_addr(sfxid)
	return 0x3200+
		(68*sfxid)+64+1
end

function get_sfx_speed(sfxid)	
	return 
		@(get_sfx_addr(sfxid))
end

function set_sfx_speed(sfxid,speed)
	poke(
		get_sfx_addr(sfxid),
		speed
	)
end
