pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _init()
	loops=3000
	draws={}
	f=0
end

function _update()
	--draws={}
	--f2=f%20
	
	for i=1,loops do
		if(rnd() < 0.5 and
		i%2 == f%2) then
		draws[i]={
     x=rnd(128),
      y=rnd(128),
      r=rnd(3),
      c=rnd({1,2,14})
		}
	end
	end
	f=f+1
end

function _draw()
	cls(7)
	
	for _,p in ipairs(draws) do
		circfill(p.x,p.y,p.r,p.c)
	end
	
	print(stat(1),4,4,11)
	print(f)
end
