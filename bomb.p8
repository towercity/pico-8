version 43
__lua__
function _init()
end

function _draw()
	camera()
	cls(2)
	tbox('we dropped the')
end
-->8
function tbox (t, p)
	-- set the area we draw in
	camera(-1,-1)
	if(p=='r') camera(-64,-1)
	-- outline
	rect(0,0,62,125,7)
	-- textbox
	rectfill(1,1,61,124,0)
	--rectfill(1,1,122,15,0)
	print(t,3,3,7)
	print('bomb\nit didnt work')
	
end
